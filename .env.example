# Token de API do 3C Plus (usuário gestor)
THREECPLUS_API_TOKEN=seu_token_aqui

# URL base da API
THREECPLUS_API_BASE=https://app.3c.plus/api/v1

# Fonte de dados: auto | api | csv
# auto = usa CSV se tiver mais ligações que a API (recomendado por enquanto)
DATA_SOURCE=auto

# Pasta onde cai o export CSV do 3C Plus
CSV_IMPORT_FOLDER=C:\Users\usuario\Downloads

# ID da planilha Google Sheets (parte da URL)
GOOGLE_SHEETS_ID=

# Caminho do JSON da conta de serviço Google
GOOGLE_SERVICE_ACCOUNT_FILE=credentials/service_account.json

# --- Dashboard remoto (Streamlit Cloud) ---
# Pasta no Drive compartilhada com a conta de serviço (Editor)
# O run.py envia data/latest.json como cobranca-latest.json
GOOGLE_DRIVE_SNAPSHOT_FOLDER_ID=

# Opcional: ID fixo do arquivo JSON (se já souber)
GOOGLE_DRIVE_SNAPSHOT_FILE_ID=

# local = PC com CSV/API | cloud = só leitura do Drive (Streamlit Cloud)
DASHBOARD_MODE=local

# Senha opcional para quem acessa o link (deixe vazio para link aberto)
VIEWER_PASSWORD=
